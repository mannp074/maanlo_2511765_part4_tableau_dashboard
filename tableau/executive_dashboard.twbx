      <aliases enabled='yes' />
      <column caption='Profit Margin' datatype='real' default-format='p0.00%' name='[Calculation_1692714508677120]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([sales]) &lt;&gt; 0 THEN&#13;&#10;    SUM([profit]) / SUM([sales])&#13;&#10;END' />
      </column>
      <column caption='Cost' datatype='real' name='[Calculation_1692714509021185]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[sales] - [profit]' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_1692714509303810]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) / COUNTD([order_id])' />
      </column>
      <column caption='Return Rate' datatype='real' name='[Calculation_1692714509430787]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([return_flag]) / COUNTD([order_id])' />
      </column>
      <column caption='Shipping Delay Bucket' datatype='string' name='[Calculation_1692714509537284]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [delivery_days] &lt;= 2 THEN&#13;&#10;    &quot;Fast (0–2 Days)&quot;&#13;&#10;ELSEIF [delivery_days] &lt;= 5 THEN&#13;&#10;    &quot;Standard (3–5 Days)&quot;&#13;&#10;ELSE&#13;&#10;    &quot;Delayed (6+ Days)&quot;&#13;&#10;END' />
      </column>
      <column caption='dashboard_sales_data' datatype='table' name='[__tableau_internal_object_id__].[dashboard!sales!data_F73E24A866274380825E4E64EC9D1733]' role='measure' type='quantitative' />
